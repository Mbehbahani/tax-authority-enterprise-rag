# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Required environment variables for the Tax Authority RAG stack
# Copy this file to .env and fill in real values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Credentials (never bake into image) ──────────────────────────────────
# For local dev: use static credentials from an IAM user with least-privilege
# policy (see docker/IAM-POLICY.md for the exact policy document).
# For CI/CD: use OIDC + assume-role to avoid static keys in repo secrets.
AWS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_AWS_SECRET_ACCESS_KEY
AWS_SESSION_TOKEN=                     # Leave blank for IAM user; set for assumed role
AWS_REGION=us-east-1

# ── Bedrock Model IDs (cross-region inference profile MANDATORY for Haiku 4.5) ─
# Legacy on-demand IDs (e.g. anthropic.claude-haiku-4-5-...) are REJECTED by Bedrock.
# The us. prefix routes through the cross-region inference profile.
BEDROCK_LLM_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_EMBED_ID=cohere.embed-multilingual-v3
BEDROCK_RERANK_ID=cohere.rerank-v3-5:0

# ── OpenSearch ────────────────────────────────────────────────────────────────
# For local compose stack: use the service name 'opensearch' as the host.
OPENSEARCH_URL=https://opensearch:9200
OPENSEARCH_USER=admin
# Must be ≥ 8 chars, mixed case + digit + special char (OpenSearch security plugin rule)
OPENSEARCH_INITIAL_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
OPENSEARCH_PASS=REPLACE_WITH_STRONG_PASSWORD
OPENSEARCH_VERIFY_CERTS=false          # demo certs; set true for prod w/ CA-signed certs

# ── Redis Stack ───────────────────────────────────────────────────────────────
REDIS_URL=redis://redis-stack:6379

# ── Observability (Jaeger OTLP) ───────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# ── Optional: evaluation mode ─────────────────────────────────────────────────
# EVAL_LLM_PROVIDER=bedrock   # default; set to 'mock' for offline unit tests
